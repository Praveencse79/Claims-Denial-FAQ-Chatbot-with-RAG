# =============================================================================
# Claims Denial FAQ Chatbot - Environment Configuration
# Copy this file to .env and fill in your credentials
# =============================================================================

# Application
APP_NAME=claims-denial-faq-chatbot
APP_ENV=development
APP_DEBUG=false
LOG_LEVEL=INFO

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1024
CLAUDE_TEMPERATURE=0.1

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=claims-denial-faq
PINECONE_DIMENSION=1536
PINECONE_METRIC=cosine

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
OPENAI_API_KEY=your_openai_api_key_here

# Snowflake Knowledge Base
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=CLAIMS_DB
SNOWFLAKE_SCHEMA=DENIAL_KB
SNOWFLAKE_ROLE=ANALYST_ROLE
SNOWFLAKE_DENIAL_TABLE=DENIAL_SCENARIOS

# RAG Configuration
RAG_TOP_K_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.75
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_MAX_CONTEXT_TOKENS=4000

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your_signing_secret

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
